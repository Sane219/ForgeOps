{
  "name": "forgeops",
  "version": "0.1.0",
  "private": true,
  "description": "ForgeOps — the internal developer platform with an AI copilot built in.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.4.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "db:migrate": "pnpm --filter @forgeops/api prisma:migrate",
    "db:seed": "pnpm --filter @forgeops/api prisma:seed",
    "db:studio": "pnpm --filter @forgeops/api prisma:studio",
    "db:generate": "pnpm --filter @forgeops/api prisma:generate",
    "docker:up": "docker compose -f infra/docker-compose.yml --env-file .env up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}
