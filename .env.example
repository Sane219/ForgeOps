# ─────────────────────────────────────────────────────────────
# ForgeOps environment variables
# Copy to `.env` (root) for shared defaults consumed by docker-compose.
# App-specific overrides can live in apps/api/.env and apps/web/.env.
# ─────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ────────────────────────────────────────────────────────
API_PORT=4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Database (Postgres 16) ─────────────────────────────────────
POSTGRES_USER=forgeops
POSTGRES_PASSWORD=forgeops_dev_pw
POSTGRES_DB=forgeops
DATABASE_URL=postgresql://forgeops:forgeops_dev_pw@localhost:5432/forgeops?schema=public

# ── Redis 7 ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_min_32_characters
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Feature flags ──────────────────────────────────────────────
# When false (default), the AI copilot UI is hidden and all AI endpoints
# are served by the deterministic provider. The app demos end-to-end
# with no API key.
FEATURE_AI_COPILOT_ENABLED=false

# ── AI provider (optional; only used when feature flag is on) ──
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001

# ── Provider selection (mock | real) ───────────────────────────
# Real implementations are out of MVP scope; these flags exist so
# swapping in real adapters later is a config change, not a refactor.
PROVIDER_ROLLOUT=mock
PROVIDER_SECURITY=mock
PROVIDER_METRICS=mock
PROVIDER_LOGS=mock
PROVIDER_ARTIFACT_PUBLISHER=db

# ── Web (Next.js public env) ───────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=ForgeOps
