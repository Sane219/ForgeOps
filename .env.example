# ─── ForgeOps local dev environment ───────────────────────────
# Copy to .env and adjust as needed.

# Database
DATABASE_URL=postgresql://forgeops:forgeops_dev_pw@localhost:5432/forgeops

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate long random strings for production
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-min32chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-min32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# App
NODE_ENV=development
API_PORT=4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Feature flags
FEATURE_AI_COPILOT_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001

# Provider selection
PROVIDER_ROLLOUT=mock
PROVIDER_SECURITY=mock
PROVIDER_METRICS=mock
PROVIDER_LOGS=mock
PROVIDER_ARTIFACT_PUBLISHER=db
