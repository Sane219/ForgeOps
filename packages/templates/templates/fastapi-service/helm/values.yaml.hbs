# Generated by ForgeOps v{{metadata.forgeopsVersion}}
# Template: fastapi-service
# Service: {{service.name}} (workspace: {{workspace.name}})
# Generated at: {{metadata.generatedAt}}

replicaCount: {{service.replicas}}

image:
  repository: {{version.image}}
  tag: "{{version.version}}"
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 80
  targetPort: {{service.port}}

resources:
  requests:
    cpu: {{cpuToFraction service.cpuMillicores}}
    memory: {{memoryToMi service.memoryMb}}
  limits:
    cpu: {{cpuToFraction (multiply service.cpuMillicores 2)}}
    memory: {{memoryToMi (multiply service.memoryMb 2)}}

livenessProbe:
  httpGet:
    path: {{service.healthcheckPath}}
    port: {{service.port}}
  initialDelaySeconds: 15
  periodSeconds: 20
  timeoutSeconds: 5
  failureThreshold: 3

readinessProbe:
  httpGet:
    path: {{service.healthcheckPath}}
    port: {{service.port}}
  initialDelaySeconds: 5
  periodSeconds: 10
  timeoutSeconds: 3
  failureThreshold: 3

ingress:
  enabled: false
  className: nginx
  annotations: {}
  hosts:
    - host: {{kebab service.name}}.local
      paths:
        - path: /
          pathType: Prefix
  tls: []

autoscaling:
  enabled: false
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 70

env:
  - name: PYTHONUNBUFFERED
    value: "1"
  - name: PYTHONDONTWRITEBYTECODE
    value: "1"
