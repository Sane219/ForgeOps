# Generated by ForgeOps v{{metadata.forgeopsVersion}}
# Template: nextjs-app
# Service: {{service.name}} (workspace: {{workspace.name}})
# Version: {{version.version}} | Image: {{version.image}}
# Generated at: {{metadata.generatedAt}}

apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{kebab service.name}}
  namespace: {{kebab workspace.name}}
  labels:
    app.kubernetes.io/name: {{kebab service.name}}
    app.kubernetes.io/version: "{{version.version}}"
    app.kubernetes.io/component: frontend
    app.kubernetes.io/part-of: {{kebab workspace.name}}
    app.kubernetes.io/managed-by: forgeops
spec:
  replicas: {{service.replicas}}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{kebab service.name}}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{kebab service.name}}
        app.kubernetes.io/version: "{{version.version}}"
      annotations:
        checksum/config: "{{version.image}}"
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 1001
        fsGroup: 1001
      containers:
        - name: {{kebab service.name}}
          image: {{version.image}}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{service.port}}
              protocol: TCP
          env:
            - name: NODE_ENV
              value: "production"
            - name: HOSTNAME
              value: "0.0.0.0"
{{{jsonEnv service.envVars}}}
          resources:
            requests:
              cpu: {{cpuToFraction service.cpuMillicores}}
              memory: {{memoryToMi service.memoryMb}}
            limits:
              cpu: {{cpuToFraction (multiply service.cpuMillicores 2)}}
              memory: {{memoryToMi (multiply service.memoryMb 2)}}
          livenessProbe:
            httpGet:
              path: {{service.healthcheckPath}}
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: {{service.healthcheckPath}}
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 3
            failureThreshold: 3
      terminationGracePeriodSeconds: 30
