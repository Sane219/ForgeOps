# Generated by ForgeOps v{{metadata.forgeopsVersion}}
# Template: go-service
# Service: {{service.name}} (workspace: {{workspace.name}})
# Version: {{version.version}} | Image: {{version.image}}
# Generated at: {{metadata.generatedAt}}

apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{kebab service.name}}
  namespace: {{kebab workspace.name}}
  labels:
    app.kubernetes.io/name: {{kebab service.name}}
    app.kubernetes.io/version: "{{version.version}}"
    app.kubernetes.io/component: backend
    app.kubernetes.io/part-of: {{kebab workspace.name}}
spec:
  replicas: {{service.replicas}}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{kebab service.name}}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{kebab service.name}}
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
      containers:
        - name: {{kebab service.name}}
          image: {{version.image}}
          ports:
            - name: http
              containerPort: {{service.port}}
              protocol: TCP
{{{jsonEnv service.envVars}}}
          resources:
            requests:
              cpu: {{cpuToFraction service.cpuMillicores}}
              memory: {{memoryToMi service.memoryMb}}
            limits:
              cpu: {{cpuToFraction (multiply service.cpuMillicores 2)}}
              memory: {{memoryToMi (multiply service.memoryMb 2)}}
          livenessProbe:
            httpGet:
              path: {{service.healthcheckPath}}
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: {{service.healthcheckPath}}
              port: http
            initialDelaySeconds: 3
            periodSeconds: 5
