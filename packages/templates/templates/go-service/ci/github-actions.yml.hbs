# Generated by ForgeOps v{{metadata.forgeopsVersion}}
# Template: go-service
# Service: {{service.name}} (workspace: {{workspace.name}})
# Version: {{version.version}} | Image: {{version.image}}
# Generated at: {{metadata.generatedAt}}

name: Build {{service.name}}

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: {{ghexpr "github.repository_owner"}}/{{kebab service.name}}

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write

    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "1.22"
          cache: true

      - name: Lint
        uses: golangci/golangci-lint-action@v4
        with:
          version: latest

      - run: go test ./... -v -race -count=1

      - if: github.event_name == 'push'
        uses: docker/login-action@v3
        with:
          registry: {{ghexpr "env.REGISTRY"}}
          username: {{ghexpr "github.actor"}}
          password: {{ghexpr "secrets.GITHUB_TOKEN"}}

      - if: github.event_name == 'push'
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {{ghexpr "env.REGISTRY"}}/{{ghexpr "env.IMAGE_NAME"}}
          tags: |
            type=sha,prefix=
            type=raw,value=latest

      - if: github.event_name == 'push'
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: {{ghexpr "steps.meta.outputs.tags"}}
          labels: {{ghexpr "steps.meta.outputs.labels"}}
          cache-from: type=gha
          cache-to: type=gha,mode=max
